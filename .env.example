# ADSRECON Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite+aiosqlite:///C:/AI_STACK/ADSRECON/adsrecon.db

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# DataImpulse Proxies (https://app.dataimpulse.com)
# Only used when cloaking is aggressive (IP-based, not fbclid-based)
DATAIMPULSE_API_KEY=your_api_key_here

# Browser Pool
BROWSER_POOL_SIZE=3
PLAYWRIGHT_BROWSERS_PATH=C:/AI_STACK/ADSRECON/.playwright

# Storage
SCREENSHOTS_DIR=C:/AI_STACK/ADSRECON/screenshots
HTML_DUMPS_DIR=C:/AI_STACK/ADSRECON/html_dumps

# Meta Scraping
META_REQUEST_DELAY_MS=2000
META_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
META_MAX_RETRIES=3

# Cloaking Bypass
# Strategy: try fbclid first (free), fall back to proxy only if needed
CLOAKING_STRATEGY=fbclid_first
FORCE_PROXY=false
